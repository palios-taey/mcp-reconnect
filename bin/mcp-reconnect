#!/usr/bin/env bash
# mcp-reconnect — Reconnect MCP servers in Claude Code tmux sessions via key injection.
#
# Claude Code has no programmatic API for MCP reconnect. The only way is through
# the interactive /mcp menu. This script automates that sequence via tmux send-keys.
#
# Key sequence:
#   Escape        → stop any active generation
#   /mcp + Enter  → submit the /mcp slash command
#   Enter         → enter the menu
#   Down + Enter  → select "Reconnect" (2nd option)
#   <prompt>      → continuation message so Claude resumes work
#
# Usage:
#   mcp-reconnect                          # All local Claude sessions
#   mcp-reconnect weaver claude            # Specific sessions by name
#   mcp-reconnect --remote devbox          # All Claude sessions on remote host
#   mcp-reconnect --remote devbox weaver   # Specific session on remote host
#   mcp-reconnect --delay 10               # Wait N seconds before starting (detached use)
#
# Requirements:
#   - tmux (Claude Code sessions must be running inside tmux)
#   - ssh (for --remote, with key-based auth configured)
#
# Design notes (learned the hard way):
#   - When called from within a Claude Code session (e.g., a deploy hook), use
#     --delay with nohup/disown so the calling session's bash tool returns before
#     Escape hits: nohup mcp-reconnect --delay 10 &>/dev/null & disown
#   - Settle times are conservative. Shorter waits cause missed keystrokes.
#   - Local sessions run in parallel (each targets a different tmux pane, no
#     contention). Remote sessions run sequentially over SSH.

set -euo pipefail

# --- Configuration -----------------------------------------------------------

SETTLE_AFTER_ESC=5        # Seconds after Escape (let generation stop)
SETTLE_AFTER_MCP=2        # Seconds after /mcp submit (menu render time)
SETTLE_AFTER_SELECT=5     # Seconds after selecting Reconnect
DELAY=0                   # Pre-start delay (--delay flag)
CONTINUATION_MSG="MCP servers reconnected with latest deployed code. Continue."

# --- Functions ---------------------------------------------------------------

usage() {
    cat <<'EOF'
Usage: mcp-reconnect [OPTIONS] [SESSION...]

Reconnect MCP servers in Claude Code tmux sessions.

Arguments:
  SESSION...              Specific tmux session names (default: auto-detect all)

Options:
  --remote HOST           Reconnect sessions on a remote machine via SSH
  --delay SECONDS         Wait before starting (for detached/nohup use cases)
  --settle-esc SECONDS    Override post-Escape settle time (default: 5)
  --settle-mcp SECONDS    Override post-/mcp settle time (default: 2)
  --settle-select SECONDS Override post-Reconnect settle time (default: 5)
  --server NAME           Target a specific MCP server by name (uses cursor tracking)
  --exclude SESSION       Skip this tmux session (for caller exclusion)
  --message MSG           Override the continuation prompt sent after reconnect
  --dry-run               Show what would be done without sending keys
  --help                  Show this help message

Examples:
  mcp-reconnect                              # Auto-detect and reconnect all
  mcp-reconnect --remote myserver            # Reconnect on remote host
  mcp-reconnect --delay 10                   # Delayed start (nohup use case)
  mcp-reconnect --dry-run                    # Preview without executing
  mcp-reconnect --server taeys-hands         # Reconnect specific MCP server
  mcp-reconnect --exclude caller-session     # Skip the calling session
EOF
    exit 0
}

die() { echo "[mcp-reconnect] ERROR: $*" >&2; exit 1; }

# Kill any previous mcp-reconnect processes (stale from prior deploys)
cleanup_previous() {
    local my_pid=$$
    local my_ppid
    my_ppid=$(ps -o ppid= -p $$ 2>/dev/null | tr -d ' ')
    local stale_pids
    # Match only 'bin/mcp-reconnect' processes, excluding ourselves and our
    # direct parent (which matches when invoked as 'bash bin/mcp-reconnect').
    stale_pids=$(
        pgrep -f 'bin/mcp-reconnect' 2>/dev/null \
            | grep -v -e "^${my_pid}$" -e "^${my_ppid}$" \
            || true
    )
    if [ -n "$stale_pids" ]; then
        echo "[mcp-reconnect] Killing stale mcp-reconnect processes: $stale_pids"
        echo "$stale_pids" | xargs kill 2>/dev/null || true
    fi
}

get_claude_sessions() {
    local sessions=()
    local session_list
    session_list=$(tmux list-sessions -F '#{session_name}' 2>/dev/null) || return 0
    while IFS= read -r session; do
        [ -z "$session" ] && continue
        local cmd
        cmd=$(tmux display-message -t "$session" -p '#{pane_current_command}' 2>/dev/null || echo "")
        if [ "$cmd" = "claude" ]; then
            sessions+=("$session")
        fi
    done <<< "$session_list"
    [ ${#sessions[@]} -gt 0 ] && printf '%s\n' "${sessions[@]}"
}

# Wait for /mcp menu to render. Returns 0 if detected, 1 if timeout.
# This is a soft check — callers should fall through to timing-based approach on failure.
wait_for_menu() {
    local session="$1"
    local max_wait="${2:-5}"
    for attempt in $(seq 1 "$max_wait"); do
        local screen
        screen=$(tmux capture-pane -t "$session" -p 2>/dev/null || true)
        # Check for known menu indicators across Claude Code versions
        if echo "$screen" | grep -qE "to navigate|Manage MCP|MCP Servers"; then
            return 0
        fi
        sleep 1
    done
    return 1
}

# Navigate to a specific server in the /mcp menu using cursor tracking.
# Returns 0 if server found and selected, 1 if not found.
navigate_to_server() {
    local session="$1"
    local target_server="$2"

    for attempt in $(seq 0 14); do
        local menu
        menu=$(tmux capture-pane -t "$session" -p 2>/dev/null | sed -n '/Manage MCP\|MCP Servers/,/to navigate\|esc to/p')
        # Look for cursor on a line containing the target server name + separator
        if echo "$menu" | grep '❯' | grep -E ' · |─' | grep -qi "$target_server"; then
            echo "[mcp-reconnect] $session: cursor on '$target_server' (attempt $attempt)"
            return 0
        fi
        tmux send-keys -t "$session" Down
        sleep 0.3
    done
    return 1
}

# Navigate to "Reconnect" in a server's submenu.
navigate_to_reconnect() {
    local session="$1"
    for attempt in $(seq 0 9); do
        local submenu
        submenu=$(tmux capture-pane -t "$session" -p 2>/dev/null | tail -20)
        if echo "$submenu" | grep '❯' | grep -qi "Reconnect"; then
            return 0
        fi
        tmux send-keys -t "$session" Down
        sleep 0.3
    done
    return 1
}

reconnect_session() {
    local session="$1"
    local target_server="${TARGET_SERVER:-}"

    if [ "${DRY_RUN:-0}" = "1" ]; then
        echo "[mcp-reconnect] DRY RUN: would reconnect session '$session'"
        return 0
    fi

    # Step 1: Escape — stop any active generation
    echo "[mcp-reconnect] $session: sending Escape..."
    tmux send-keys -t "$session" Escape
    sleep "$SETTLE_AFTER_ESC"

    # Step 2: /mcp + Enter — open the MCP menu
    echo "[mcp-reconnect] $session: sending /mcp + Enter..."
    tmux send-keys -t "$session" -l "/mcp"
    sleep 0.3
    tmux send-keys -t "$session" Enter

    # Step 3: Wait for menu to render (soft check — fall through on timeout)
    local menu_detected=0
    if wait_for_menu "$session" 5; then
        menu_detected=1
        echo "[mcp-reconnect] $session: menu detected"
    else
        echo "[mcp-reconnect] $session: menu detection timeout — using timing-based fallback"
        sleep "$SETTLE_AFTER_MCP"
    fi

    # Step 4: Navigate and select Reconnect
    if [ -n "$target_server" ] && [ $menu_detected -eq 1 ]; then
        # Smart targeting: find the specific server, enter its submenu, select Reconnect
        if navigate_to_server "$session" "$target_server"; then
            tmux send-keys -t "$session" Enter
            sleep 2
            navigate_to_reconnect "$session"
            tmux send-keys -t "$session" Enter
        else
            echo "[mcp-reconnect] $session: '$target_server' not found — falling back to default"
            # Fall through to default behavior
            tmux send-keys -t "$session" Enter
            sleep 0.5
            tmux send-keys -t "$session" Down
            sleep 0.3
            tmux send-keys -t "$session" Enter
        fi
    else
        # Default behavior (v1.1.0 proven pattern): Enter → Down → Enter
        echo "[mcp-reconnect] $session: Enter (menu) → Down → Enter (reconnect)..."
        tmux send-keys -t "$session" Enter
        sleep 0.5
        tmux send-keys -t "$session" Down
        sleep 0.3
        tmux send-keys -t "$session" Enter
    fi

    # Step 5: Wait for reconnection
    # Try signal-based wait first (look for "Reconnected to" in pane),
    # fall back to fixed timer if signal not detected
    echo "[mcp-reconnect] $session: waiting for reconnection..."
    local reconnect_confirmed=0
    for _w in $(seq 1 "$SETTLE_AFTER_SELECT"); do
        if tmux capture-pane -t "$session" -p 2>/dev/null | grep -qi "Reconnected"; then
            echo "[mcp-reconnect] $session: reconnection confirmed"
            reconnect_confirmed=1
            break
        fi
        sleep 1
    done
    if [ $reconnect_confirmed -eq 0 ]; then
        echo "[mcp-reconnect] $session: no reconnection signal — waited ${SETTLE_AFTER_SELECT}s (may still be OK)"
    fi

    # Step 6: Send continuation prompt
    echo "[mcp-reconnect] $session: sending continuation prompt..."
    # Clear any stale input first (C-a = beginning of line, C-k = kill to end)
    tmux send-keys -t "$session" C-a C-k
    sleep 0.2
    tmux send-keys -t "$session" -l "$CONTINUATION_MSG"
    sleep 0.3
    tmux send-keys -t "$session" Enter

    echo "[mcp-reconnect] $session: done"
}

reconnect_remote() {
    local host="$1"
    shift
    local sessions=("$@")

    echo "[mcp-reconnect] Remote: $host"

    if [ "${DRY_RUN:-0}" = "1" ]; then
        echo "[mcp-reconnect] DRY RUN: would reconnect on remote host '$host'"
        return 0
    fi

    # If no specific sessions given, find Claude sessions on remote
    if [ ${#sessions[@]} -eq 0 ]; then
        local remote_sessions
        remote_sessions=$(ssh -o ConnectTimeout=5 "$host" bash -c '
            for s in $(tmux list-sessions -F "#{session_name}" 2>/dev/null); do
                cmd=$(tmux display-message -t "$s" -p "#{pane_current_command}" 2>/dev/null || echo "")
                [ "$cmd" = "claude" ] && echo "$s"
            done
        ' 2>/dev/null) || die "SSH connection to $host failed"

        if [ -z "$remote_sessions" ]; then
            echo "[mcp-reconnect] $host: no Claude sessions found"
            return 0
        fi
        mapfile -t sessions <<< "$remote_sessions"
    fi

    # Sequential over SSH — one session at a time
    for session in "${sessions[@]}"; do
        [ -z "$session" ] && continue
        echo "[mcp-reconnect] $host/$session: reconnecting..."
        ssh -o ConnectTimeout=5 "$host" bash -s -- "$session" \
            "$SETTLE_AFTER_ESC" "$SETTLE_AFTER_MCP" "$SETTLE_AFTER_SELECT" \
            "$CONTINUATION_MSG" <<'RECONNECT_EOF'
SESSION="$1"; T_ESC="$2"; T_MCP="$3"; T_SEL="$4"; MSG="$5"
tmux send-keys -t "$SESSION" Escape
sleep "$T_ESC"
tmux send-keys -t "$SESSION" -l "/mcp"
sleep 0.3
tmux send-keys -t "$SESSION" Enter
sleep "$T_MCP"
tmux send-keys -t "$SESSION" Enter
sleep 0.5
tmux send-keys -t "$SESSION" Down
sleep 0.3
tmux send-keys -t "$SESSION" Enter
sleep "$T_SEL"
tmux send-keys -t "$SESSION" C-a C-k
sleep 0.2
tmux send-keys -t "$SESSION" -l "$MSG"
sleep 0.3
tmux send-keys -t "$SESSION" Enter
echo "[mcp-reconnect] $SESSION: done"
RECONNECT_EOF
    done
}

# --- Argument Parsing --------------------------------------------------------

DRY_RUN=0
REMOTE_HOST=""
TARGET_SERVER=""
EXCLUDE_SESSION=""
POSITIONAL=()

while [ $# -gt 0 ]; do
    case "$1" in
        --help|-h)          usage ;;
        --remote)           REMOTE_HOST="${2:?--remote requires a hostname}"; shift 2 ;;
        --delay)            DELAY="${2:?--delay requires a number}"; shift 2 ;;
        --settle-esc)       SETTLE_AFTER_ESC="${2:?--settle-esc requires a number}"; shift 2 ;;
        --settle-mcp)       SETTLE_AFTER_MCP="${2:?--settle-mcp requires a number}"; shift 2 ;;
        --settle-select)    SETTLE_AFTER_SELECT="${2:?--settle-select requires a number}"; shift 2 ;;
        --message)          CONTINUATION_MSG="${2:?--message requires text}"; shift 2 ;;
        --server)           TARGET_SERVER="${2:?--server requires a server name}"; shift 2 ;;
        --exclude)          EXCLUDE_SESSION="${2:?--exclude requires a session name}"; shift 2 ;;
        --dry-run)          DRY_RUN=1; shift ;;
        -*)                 die "Unknown option: $1" ;;
        *)                  POSITIONAL+=("$1"); shift ;;
    esac
done

export TARGET_SERVER

# --- Main --------------------------------------------------------------------

# Kill stale instances from prior runs
cleanup_previous

# Pre-start delay (for nohup/detached use case)
if [ "$DELAY" -gt 0 ] 2>/dev/null; then
    echo "[mcp-reconnect] Waiting ${DELAY}s before starting..."
    sleep "$DELAY"
fi

# Remote mode
if [ -n "$REMOTE_HOST" ]; then
    reconnect_remote "$REMOTE_HOST" "${POSITIONAL[@]}"
    exit 0
fi

# Local mode
if [ ${#POSITIONAL[@]} -gt 0 ]; then
    SESSIONS=("${POSITIONAL[@]}")
else
    mapfile -t SESSIONS < <(get_claude_sessions)
fi

# Filter out excluded session (e.g., the caller)
if [ -n "$EXCLUDE_SESSION" ] && [ ${#SESSIONS[@]} -gt 0 ]; then
    FILTERED=()
    for s in "${SESSIONS[@]}"; do
        if [ "$s" != "$EXCLUDE_SESSION" ]; then
            FILTERED+=("$s")
        else
            echo "[mcp-reconnect] Excluding session '$s' (caller)"
        fi
    done
    SESSIONS=("${FILTERED[@]}")
fi

if [ ${#SESSIONS[@]} -eq 0 ]; then
    echo "[mcp-reconnect] No Claude Code sessions found in tmux"
    exit 0
fi

echo "[mcp-reconnect] Reconnecting ${#SESSIONS[@]} session(s): ${SESSIONS[*]}"

# Parallel — each session targets a different tmux pane, no contention
for session in "${SESSIONS[@]}"; do
    [ -z "$session" ] && continue
    reconnect_session "$session" &
done
wait

echo "[mcp-reconnect] All sessions reconnected"
